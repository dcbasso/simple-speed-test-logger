{
  "interval_minutes": 15,
  "speedtest": {
    "binary_path": "speedtest",
    "timeout_seconds": 60
  },
  "google": {
    "service_account_key_path": "/etc/speedtest-logger/service-account.json",
    "spreadsheet_id": "COLOQUE_O_ID_DA_PLANILHA_AQUI",
    "sheet_range": "tests!A:G"
  },
  "log": {
    "path": "/var/log/speedtest-logger.log",
    "level": "info"
  }
}
