# Required — GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# Firestore database ID (defaults to "(default)" if omitted)
FIRESTORE_DATABASE=(default)

# Fallback alert email (used if monitor_config/current does not exist in Firestore)
ALERT_EMAIL=youremail@gmail.com

# Fallback threshold in minutes (used if monitor_config/current does not exist in Firestore)
MAX_MINUTES_WITHOUT_DATA=45

# Gmail OAuth2 credentials — inject from Secret Manager in Cloud Functions config
# See gcp/docs/pre-requisites.md Step 6 for how to obtain these values
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
